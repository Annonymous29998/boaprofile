# =============================================================================
# LOCAL ONLY (do not add PORT on Vercel)
# =============================================================================
PORT=3000

# =============================================================================
# COPY EVERYTHING BELOW INTO VERCEL
# Project → Settings → Environment Variables
# Enable: Production, Preview, Development → then Redeploy
# =============================================================================

JWT_SECRET=your-long-random-secret-at-least-32-characters

SUPABASE_URL=https://your-project-id.supabase.co

SUPABASE_ANON_KEY=your-supabase-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

MAX_USERS=0

ADMIN_USERNAME=your-admin-username

ADMIN_PASSWORD=your-admin-password

# Optional first-seed passwords (local/.env / Vercel only — never hardcode in source)
# SEED_MEGAN_PASSWORD=
# SEED_ALAN_PASSWORD=

# Optional: only for local Playwright tests (do not add to Vercel)
# TEST_CUSTOMER_USERNAME=
# TEST_CUSTOMER_PASSWORD=
# TEST_CUSTOMER_NAME=
